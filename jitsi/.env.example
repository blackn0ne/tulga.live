# Where Jitsi will store generated configs and state
CONFIG=./.jitsi-meet-cfg

# Container image tag
JITSI_IMAGE_VERSION=latest
RESTART_POLICY=unless-stopped

# Host-side port that Apache will proxy to
HTTP_PORT=8088

# Your public Jitsi URL
PUBLIC_URL=https://jitsi.tulga.kz

# Time zone
TZ=Asia/Almaty

# We terminate HTTPS in Apache, not inside the web container
DISABLE_HTTPS=1

# Internal XMPP layout
XMPP_SERVER=xmpp.meet.jitsi
XMPP_PORT=5222
XMPP_DOMAIN=meet.jitsi
XMPP_AUTH_DOMAIN=auth.meet.jitsi
XMPP_GUEST_DOMAIN=guest.meet.jitsi
XMPP_MUC_DOMAIN=muc.meet.jitsi
XMPP_INTERNAL_MUC_DOMAIN=internal-muc.meet.jitsi
XMPP_HIDDEN_DOMAIN=hidden.meet.jitsi
XMPP_RECORDER_DOMAIN=recorder.meet.jitsi
PROSODY_HTTP_PORT=5280

# Media / NAT
JVB_PORT=10000
JVB_COLIBRI_PORT=8080
JVB_AUTH_USER=jvb
JVB_ADVERTISE_IPS=YOUR_SERVER_PUBLIC_IP
JVB_WS_DOMAIN=jitsi.tulga.kz

# Security / access mode
ENABLE_AUTH=1
ENABLE_GUESTS=0
ENABLE_LOBBY=1
ENABLE_AUTO_OWNER=0
ENABLE_MODERATOR_CHECKS=1
ENABLE_COLIBRI_WEBSOCKET=1
ENABLE_XMPP_WEBSOCKET=1
AUTH_TYPE=jwt

# Jitsi token auth
JWT_APP_ID=tulga-live
JWT_APP_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ACCEPTED_ISSUERS=tulga-live
JWT_ACCEPTED_AUDIENCES=jitsi
JWT_ALLOW_EMPTY=0

# Required service account passwords
JICOFO_AUTH_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
JVB_AUTH_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
